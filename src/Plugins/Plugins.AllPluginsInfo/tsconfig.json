{
	"compileOnSave": false,
	"compilerOptions": {
		"sourceMap": true,
		"target": "es5",
		"module": "esnext",
		"declaration": false,
		"noImplicitAny": false,
		"removeComments": true,
		"experimentalDecorators": true,
		"noLib": false,
		"jsx": "react",
		"allowSyntheticDefaultImports": true,
		"moduleResolution": "node",
		"pretty": true,
"skipLibCheck":true
	}
}